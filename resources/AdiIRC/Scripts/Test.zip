on *:KICK:#makati: {
  set %log.maker.kmsg $strip($1-)
  if ($chr(60) isin %log.maker.kmsg) { set %log.maker.kmsg $replace(%log.maker.kmsg,$chr(60),&lt;) }
  if ($chr(62) isin %log.maker.kmsg) { set %log.maker.kmsg $replace(%log.maker.kmsg,$chr(62),&gt;) }
  set %log.maker.file $remove(logs- $+ $adate $+ .html,$chr(47))
  if ($file(%log.maker.file) == $null) { write %log.maker.file <title> $adate #Makati Logs </title><font face="verdana" size=2><strong>#Makati Logs for $adate <br>LOG MAKER v1.01 Script by siLverbLade</strong><br><br> }
  set %log.maker.printline $strip($timestamp) <font color="FF00FF"> * $knick was kicked by $nick ( $+ %log.maker.kmsg $+ ) </font><br>
  write %log.maker.file %log.maker.printline
  unset %log.maker.printline
  unset %log.maker.kmsg
}
on *:TOPIC:#makati: {
  set %log.maker.topic $strip($1-)
  if ($chr(60) isin %log.maker.topic) { set %log.maker.topic $replace(%log.maker.topic,$chr(60),&lt;) }
  if ($chr(62) isin %log.maker.topic) { set %log.maker.topic $replace(%log.maker.topic,$chr(62),&gt;) }
  set %log.maker.file $remove(logs- $+ $adate $+ .html,$chr(47))
  if ($file(%log.maker.file) == $null) { write %log.maker.file <title> $adate #Makati Logs </title><font face="verdana" size=2><strong>#Makati Logs for $adate <br>LOG MAKER v1.01 Script by siLverbLade</strong><br><br> }
  write %log.maker.file $strip($timestamp) <font color="FF9B06"> *<strong> $nick </strong>changes topic to ' $+ %log.maker.topic $+ ' </font><br>
  unset %log.maker.topic
}
on *:DISCONNECT: {
  set %log.maker.file $remove(logs- $+ $adate $+ .html,$chr(47))
  if ($file(%log.maker.file) == $null) { write %log.maker.file <title> $adate #Makati Logs </title><font face="verdana" size=2><strong>#Makati Logs for $adate <br>LOG MAKER v1.01 Script by siLverbLade</strong><br><br> }
  write %log.maker.file $strip($timestamp) <font color="CCCCCC"> Quits: $me (Disconnected From Server) Please Contact siLverblade / sneakers for assistance </font><br>
  write %log.maker.file $strip($timestamp) <font color="009900"><strong>---------- Chronus Quitted from DALnet [Logging Suspended] ----------</font><br><br>Sorry for the inconvenience. Logging will be back soon. [siLverbLade]</strong><br><br>
}
