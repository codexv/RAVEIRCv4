  set %log.maker.printline $strip($timestamp) <font color="FF9900"> * $nick sets mode: %log.maker.op </font><br>
  if (%log.maker.printline isin $read(%log.maker.file,$lines(%log.maker.file))) { halt }
  write %log.maker.file %log.maker.printline
