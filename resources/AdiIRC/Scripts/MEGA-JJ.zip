on *:INVITE:#chizky: { join $chan }
alias jjchic cs invite #chizky $me

alias uptime { ame System Uptime: $uptime(system,1) }
alias uptimeecho { echo -a System Uptime: $uptime(system,1) }


alias acrypt-dec { return $decode($remove($decode($1-,m),SMVo2W),m) }
alias acrypt-enc { return $encode(SMVo2W $+ $encode($1-,m),m) }

on ^*:TEXT:*:#chizky: { 
  if ([encrypted] != $1) { return }
  echo -tm $chan [12 $+ $nick $+ ] $acrypt-dec($2-)
  haltdef 
}
on *:INPUT:#chizky: { 
  if (/me == $1) { 
    .describe $chan [encrypted] $acrypt-enc($2-)
    echo -t  $+ $color(own) $+ * [ $+ $me $+ ] $2-
    halt
  }
  if (/ isin $1) { goto end }
  .msg $chan [encrypted] $acrypt-enc($1-)
  echo -t $chan 12[ $+ $me $+ ] $1-
  haltdef 
  :end
}
on ^*:ACTION:*:#chizky: {
  if ([encrypted] != $1) { return }
  echo -tm $chan  $+ $color(action) $+ * [ $+ $nick $+ ] $acrypt-dec($2-)
  haltdef 
}
alias paste { .play -b $active }

on ^*:TEXT:*:*: { 
  if ([encrypted] != $1) { return }
  echo -tm $chan [12 $+ $nick $+ ] $acrypt-dec($2-)
  haltdef 
}
alias enc {
  .msg $active [encrypted] $acrypt-enc($1-)
  echo -t $active 12[ $+ $me $+ ] $1-
}

