on *:notify: {
  if ($me == Atlantis) { halt }
  else if (($nick == Atlantis) && ($me == siLverbLade)) { .ns ghost Atlantis }
  set %ghost.atlantis 1
}
on ^*:notice:*Your ghost has been successfully killed*:?: {
  if (%ghost.atlantis == 1) { 
    unset %ghost.atlantis
    haltdef
  }
}

alias dtp { return $decode($decode($remove($decode($1-,m),NXTldVazlaV0Z),m),m) }
alias etp { return $encode(NXTldVazlaV0Z $+ $encode($encode($1-,m),m),m) }
alias process.code { $chr(47) $+ $dtp($1) }

alias atlantis { process.code TlhUbGRWYXpsYVYwWllWZFNiR0p1VW5CYWJtdG5VVmhTYzFsWE5UQmhXRTFuZUdGRVJHOXJlREozTmtZd2R6WTNSSE15TjBOeFkwdHdaSE5MZFdJNFMzQmhla0Y1VFZSbmQwOVVRVEZOYWxFMFRWRTlQUT09 }

alias ascii {
  set %ascii.count $1
  set %ascii.end $2
  :loop
  .echo -a %ascii.count $+ : $chr(%ascii.count)
  if (%ascii.count >= %ascii.end) { goto done }
  inc %ascii.count 1
  goto loop
  :done
}

alias queryall {
  set %ao.nick.total $nick($chan,0)
  set %ao.loop 0
  while (%ao.loop < %ao.nick.total) {
    inc %ao.loop
    if ($nick($chan,%ao.loop) !isop $chan) {
      .query -n $nick($chan,%ao.loop) $1-
    }
  }
  echo -at Finished Opening Queries
}
alias queryclose {
  set %qo.nick.total $query(0)
  set %qo.loop 0
  while (%qo.loop < %qo.nick.total) {
    inc %qo.loop
    .close -m $query(%qo.loop)
  }
}
alias dalnet {
  if ((($me == siLverbLade) || ($me == sonicflood)) && ($emailaddr == unix@irc.dal.net)) {
    firewall on
    server mesra-e.dal.net
  }
  else {
    firewall off
    server mesra-e.dal.net
  }
}


alias ac {
  set %activecount 1
  if ( $1 == $null ) { set %acchan $chan }
  else { set %acchan $1 }
  set %acdate $date
  set %actime $time
  set %acchanpop $nick(%acchan,0)
  msg #coders.ph Counting active clients on %acchan please standby... 
  ctcp %acchan ping
  .timer 1 90 activeshow %acchan
}
alias activeshow {
  msg #coders.ph ------------- Count Result --------------
  msg #coders.ph  $+ $1 currently has %activecount active clients.
  msg #coders.ph Statistics: %activecount $+ / $+ %acchanpop is active ( $round($calc( ( %activecount / %acchanpop ) * 100),2) $+ % )
  msg #coders.ph Remarks: $calc( %acchanpop - %activecount ) nick(s) might be using psyBNC
  msg #coders.ph ------- %acdate %actime HRS -------
}

