on *:join:#makati: {
  if (($me isop $chan) && ($nick == chizky)) { vc }
  if ($nick(#makati,0) > %makatipeak) { 
    set %makatipeak $nick(#makati,0)
    set %mpeaktime $date $time
    set %mpeak Peak: %makatipeak Users on %mpeaktime
  }
}
on *:part:#makati: {
  if ($calc($nick(#makati,0) - 1) < %makatifloor) { 
    set %makatifloor $calc($nick(#makati,0) - 1) 
    set %mfloortime $date $time
    set %mfloor Lowest: %makatifloor Users on %mfloortime
  }
}
on *:quit: {
  if ($nick(#makati,0) < %makatifloor) { 
    set %makatifloor $calc($nick(#makati,0) - 1) 
    set %mfloortime $date $time
    set %mfloor Lowest: %makatifloor Users on %mfloortime
  }
}

