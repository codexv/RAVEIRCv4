alias md5 {
  set %md5orig $$?="Enter Original MD5:"
  if ($1 == %md5orig) { echo -at 3MD5 Check Sums MATCHED }
  else { echo -at 4MD5 Check Sums are different! :( }
  unset %md5orig
}



