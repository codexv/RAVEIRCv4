;====== coders.ph encryption =======
alias coders-dec { return $decode($remove($decode($1-,m),HZXRsA),m) }
alias coders-enc { return $encode(HZXRsA $+ $encode($1-,m),m) }
alias x {
  .msg $active [code] $coders-enc($1-)
  echo -t $active 12+[ $+ $me $+ ]+ $1-
}
on ^*:TEXT:*:#: { 
  if ([code] != $1) { return }
  echo -tm $chan +[12 $+ $nick $+ ]+ $coders-dec($2-)
  haltdef 
}
on ^*:TEXT:*:?: { 
  if ([code] != $1) { return }
  echo -tm $nick +[12 $+ $nick $+ ]+ $coders-dec($2-)
  haltdef 
}
