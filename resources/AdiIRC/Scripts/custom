;================================ DRONE KICK ================================;
on *:join:#:{
  set %not.drone coicoi Alexis Auie RaNdY Ran LoNDoNBabE Roselle NogNog switfemme chizky chic sneakers tyra siLverbLade KanKouni Elmer rainelopez sheryll gracel
  if ($remove($gettok($address($nick,1),1,64),*!*) isin $nick) && ($me isop #makati) && ($len($nick) == 3) && ($istok(%not.drone,$nick,32) == $false) { 
    .who $nick 
    .set %virusinfctd 1
    .timervirus off 
  } 
}
raw 315:*: { if (%virusinfctd == 1) { haltdef | .timervirus 1 5 unset %virusinfctd } }
raw 352:*: { 
  if ($6 == $9) && ($me isop #makati) && (%virusinfctd == 1) { 
    if ($6 ison #makati) { kick #makati $6 -DRONE }
    ban -u7200 #makati $4 
    haltdef 
  }
  if (%virusinfctd == 1) { haltdef }
}
