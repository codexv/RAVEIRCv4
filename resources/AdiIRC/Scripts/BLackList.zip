    if (%oz.nOZnk10 == $null) { unset %oz.nOZnk10 }
    if (%oz.nOZnk11 == $null) { unset %oz.nOZnk11 }
    if (%oz.nOZnk12 == $null) { unset %oz.nOZnk12 }
