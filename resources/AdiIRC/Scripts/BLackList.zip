on *:connect:{
  unset %oz.nOZsense
}

menu menubar,channel {
  Nonsense Nick:.oznOzsense
  -
}

on 1:unload:{
  echo -a 10*** Succesfully unloaded Oz Nonsense Nick Removal ©
  echo -a 10*** Succesfully unloaded BLackList Organizer ©
  unset %oz.nOZn*
  unset %oz.nOZsense*
}

alias oznOzsense { if ($dialog(oznOzsense) == $null) dialog -md oznOzsense oznOzsense }
dialog oznOzsense {
  title "Oz Nosense Nick Removal"
  size -1 -1 225 103
  option dbu
  button "- Exit -", 1, 190 85 30 10, cancel
  button "", 32, 190 63 30 10
  button "", 2, 5 85 28 10
  button "", 3, 42 85 28 10
  button "", 20, 79 85 28 10
  button "", 30, 116 85 28 10
  button "", 31, 153 85 28 10
  box "Kick/Ban",21, 2 77 35 22
  box "Ban Type",22, 39 77 35 22
  box "Ban Secs",23, 76 77 35 22
  box "Echo",24, 113 77 35 22
  box "Severity",25, 150 77 35 22
  box "Close",26, 187 77 37 22
  box "Ignore",27, 187 55 37 22
  box "Add partial or complete Nick/Username here to be exempted from kicks",4, 2 2 222 53
  box "Kick Reason",5, 2 55 183 22
  edit "", 6, 5 62 177 10,autohs
  edit "", 7, 5 10 50 10,autohs
  edit "", 8, 60 10 50 10,autohs
  edit "", 9, 115 10 50 10,autohs
  edit "", 10, 170 10 50 10,autohs
  edit "", 11, 5 25 50 10,autohs
  edit "", 12, 60 25 50 10,autohs
  edit "", 13, 115 25 50 10,autohs
  edit "", 14, 170 25 50 10,autohs
