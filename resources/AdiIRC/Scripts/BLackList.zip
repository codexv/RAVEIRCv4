on 1:load: {
  echo -a 
  echo -a 10*** Thank You for loading ( MEGA ® ) BLackList Organizer 
  echo -a 10*** Type /blacklist or select the BLackList Manager on your Pop-ups
  echo -a 10*** to open the BLackList Manager Dialog box
  echo -a 10*** Succesfully loaded Oz Nonsense Nick Removal ©
  echo -a 10*** Please note this may not work on older versions of mIRC prior to ver 6.01 
  echo -a 
}

menu channel,menubar,status {
  -
  BLackList Editor:/dialog -m comp304 comp304
}

alias blacklist {
  dialog -m comp304 comp304
}

dialog comp304 {
  title "( MEGA ® ) BLackList Editor"
  size -1 -1 181 122
  icon icon\snb.ico, index
  option dbu
  combo 762,2 4 177 50, vsbar
  button "Close",2, 142 110 35 10,ok,
  button "Add",3, 54 110 35 10
  button "Remove",4, 92 110 35 10
  button "Clear All",11, 4 110 35 10
  text "To add a user to this list, the following are a few examples:",5, 2 50 177 10
  text "Nick , Nick!user@isp.com  , *!*@isp.com  , *!*user@* , *!*user@isp.com ,",6, 2 57 177 10
  text "Nick*!*@230.192.0.* , *!*user@230.192.0.* etc, etc.",7, 2 64 177 10
  text "Your user entries will be banned from all Channels your Op'd on. ",8, 2 71 177 10
  text "Kick Message:",10, 2 85 50 8
  edit "",9, 2 93 177 10,autohs
}

on *:DIALOG:comp304:init:0: {
  if (%ozmode.blklist != $null) { did -a comp304 9 %ozmode.blklist }
  if (%ozmode.blklist = $null) { set  %ozmode.blklist 4You are banned from all channels i'm on 5:: [[ MEGA ® ] 5:: | did -a comp304 9 %ozmode.blklist } 
  update.setupsl
}
alias -l update.setupsl {
  did -r comp304 762
  set %tempsl.total $count(%setupsl.list,$chr(44))
  set %tempsl.count 0
  :start
  inc %tempsl.count 1
  did -a comp304 762 $gettok(%setupsl.list,%tempsl.count,44)
  if (%tempsl.count < %tempsl.total) { goto start }
}
on *:DIALOG:comp304:edit:*: {
  set %ozmode.blklist $did(9)
  if ($did == 762) {
    set %setupsl.temp.user $did(762).text
  }
}
on *:DIALOG:comp304:sclick:*: {
  if ($did == 3) {
    set %setupsl.list %setupsl.list $+ %setupsl.temp.user $+ ,
    update.setupsl
    auser 100 %setupsl.temp.user | unset %setupsl.temp.user
  }
  if ($did == 4) {
    set -u1 %setupsl.tc %setupsl.user.selected $+ ,
    set %setupsl.list $remove(%setupsl.list,%setupsl.tc)
    update.setupsl
    ruser 100 %setupsl.user.selected
  }
  if ($did == 762) {
    set %setupsl.user.selected $did($dname,762,$did(762).sel) 
  }
  if ($did == 11 ) { .rlevel -r 100 | unset %setupsl.temp.user | unset %setupsl.list* | echo -a 10*** 4BlackList10 has been cleared | did -a comp304 762 } 
}
alias slentry {
  set %setupsl.list %setupsl.list $+ %setupsl.temp.user $+ ,
  update.setupsl
  auser 100 %setupsl.temp.user | unset %setupsl.temp.user
}

alias slentry1 {
  set %setupsl.list %setupsl.list $+ %setupsl.temp.user $+ ,
  update.setupsl
  guser 100 %setupsl.temp.user | unset %setupsl.temp.user
}



