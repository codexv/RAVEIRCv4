raw 441:*: { haltdef }
raw 442:*: { echo 2 -at 2-5[ 4RAVE 5]-3 You're not on that channel }
raw 443:*: { echo 2 -at 2-5[ 4RAVE 5]-3 4 $+ $2 $+ :3 is already on channel }
raw 464:*: { echo 2 -at 2-5[ 4RAVE 5]-3 Password incorect }
raw 477:*: { echo 2 -at 2-5[ 4RAVE 5]-3 Channel doesn't support modes }
raw 478:*: { echo 2 -at 2-5[ 4RAVE 5]-3 4 $+ $2 $+ :3 Channel List is Full }
raw 485:*: { echo 2 -at 2-5[ 4RAVE 5]-3 Channel Has Been Closed by DALnet | halt }
raw 401:*: { echo 2 -at 2-5[ 4RAVE 5]-3 No O-lines for your host }
raw 353:*: { 
  haltdef
  if (%mega.all.autokicks == OFF) { goto end }
  if ($istok(%mega.Offnick.channels,$3,32) == $false) { goto end }
  set %bntrigtotal $numtok(%badnick,32)
  set %BNCR 1
  set %nthn 1
  .timer 1 30 unset %nmtchtotal. [ $+ [ $3 ] ]
  :loopcheck
  if ($matchtok($4-,$gettok(%badnick,%BNCR,32),0,32) > 0) {
    inc %nmtchtotal. [ $+ [ $3 ] ] $matchtok($4-,$gettok(%badnick,%BNCR,32),0,32)
    set -u30 %cndetected. [ $+ [ $3 ] ] 1
    set %n 1
    :nthnick
    if ($matchtok($4-,$gettok(%badnick,%BNCR,32),%n,32) != $null) {
      set %cnd. [ $+ [ $3 ] ] [ $+ [ %nthn ] ] $matchtok($4-,$gettok(%badnick,%BNCR,32),%n,32)
      inc %n 1
      inc %nthn 1
      goto nthnick
    }
  }
  if (%BNCR >= %bntrigtotal) { goto end }
  inc %BNCR 1
  goto loopcheck
  :end
}
raw 366:*: { 
  haltdef 

  echo -nt @intel 5***14 Channel Count:4 $nick($2,0) 5user(s) on4 $2 5***
}
raw 1:*: { 
  echo -st 0 $+ $8
  set -u30 %rno.dont 7
  haltdef 
}

raw 433:*: { 
  .echo 2 -at -5[ 4RAVE 5]-4 $2 3Nickname is already in use. | haltdef
  if ($istok(%rno.auto.g,$2,32) == $true) {
    set %rno.pls.change $2
    set %rno.request ghost
    .echo 2 -at -5[ 4RAVE 5]-3 Attempting to GHOST4 $2 $+ 3...
    .ns ghost $2 %rno.password. [ $+ [ $2 ] ]



  }


  .echo 2 -at -5[ 4RAVE 5]-3You have not registered | haltdef
  if ($anick == $null) { nick $mnick $+ $rand(0,9) $+ $rand(0,9) }
  if ((%rno.pls.change != $null) && (%rno.request == ghost)) { 
    .echo 2 -at -5[ 4RAVE 5]-3Re-Attempting GHOST in 5sec...
    .timer 1 5 ghost.reattempt
  }
  if ((%rno.pls.change != $null) && (%rno.request == release)) { 
    .echo 2 -at -5[ 4RAVE 5]-3Re-Attempting RELEASE Request in 5sec...
    .timer 1 5 release.reattempt
  }
}
