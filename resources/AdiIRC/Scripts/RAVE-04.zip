;============================= RAVE 4.01 Sounds setup ==================================
;•••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••
#mega.sounds off
on *:JOIN:#:{ if ($nick == $me) .splay -w sounds\wavs\welcome.wav }
on *:PART:#:{ if ($nick == $me) .splay -w sounds\wavs\goodbye.wav }
on *:ACTION:lol:#:{ .splay -w sounds\wavs\LoL.wav }
on *:CLOSE:*:{ .splay -w sounds\wavs\msgback.wav }
on *:CONNECT:{ .splay -w sounds\wavs\connected.wav }
on *:DISCONNECT:{ .splay -w sounds\wavs\terminate.wav }
on *:KICK:#:{ if (($knick != $me) && ($nick == $me)) { .splay -w sounds\wavs\Aaaao.wav } }
#mega.sounds end
ctcp *:PAGE:*:{ .splay -w sounds\wavs\Page.wav }

;•••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••
;================================== NETsplit Alert ======================================
;•••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••
on 1:Quit:{
  if (%netsplit == $null) { set %netsplit on }
  if (%netsplit == on) {
    if ((dal.net isin $right($1,7)) && (dal.net isin $right($2,7))) {
      if ($1- == %split) { halt }
      set %split1 $gettok($1,1-,46)
      set %split2 $gettok($2,1-,46)
      echo -t @intel 14-[ NetSplit ]-4 %split1 14From4 %split2 %kicklogo
      set -u5 %split $1-
      set %netsplitevident 1
      goto middle
    }
  }
  :middle
  if (%netsplit2 == $null) { set %netsplit2 ON }
  if (%netsplit2 == ON) {
    if ((dal.net isin $right($1,7)) && (dal.net isin $right($2,7))) {
      set %split1 $gettok($1,1-,46) | set %split2 $gettok($2,1-,46)
      .ame 14NetSplit Alert:4 %split1 14From4 %split2 %kicklogo
      echo -t @intel 14-[ NetSplit ]-4 Broadcasted Netsplit on Channels.
      set -u5 %split $1-
    }
  }
  :end
}


;•••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••
;=========================== RAVE 4.01 Nick Completer Pro =================================
;=========== responds with ";" Example: to address to siLverbLade just type: sil; hi there! ===============
;====== and your message will look like: siLverbLade: hi there! You could also type: blade; hi there! =========
;========= which yields the same result. Your keystring must be the first word of your text. ==============
;•••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••

on *:INPUT:#: {
  if ($right($1,1) == $chr(59)) {
    set %nc.msg $deltok($1-,1,32)
    set %nc.nicks.total $nick($chan,0)
    set %nc.var 1
    :loopcheck
    if ($remove($1,$chr(59)) isin $nick($chan,%nc.var)) {

      set %nc.nick $nick($chan,%nc.var)
      goto process
    }
    if (%nc.var >= %nc.nicks.total) { goto process }
    inc %nc.var 1
    goto loopcheck
    :process
    if ((%nc.nick == $null) && (%nc.msg != $null)) { 
      echo -a 10* No matches were found for * $+ $remove($1,$chr(59)) $+ *
      unset %nc.*
      goto end
    }
    if ((%nc.nick == $null) && (%nc.msg == $null)) { 
      echo -a 10* No matches were found for * $+ $remove($1,$chr(59)) $+ *
      unset %nc.*
      halt
    }
    if (%nc.msg == $null) {
      msg $chan %nc.nick
      unset %nc.*
      halt
    }
    msg $chan %nc.nick $+ : %nc.msg
    unset %nc.*
    halt
  }
  :end
}


;•••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••
;================================== Alias Manager ======================================
;•••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••

dialog alias.manager {
  title "RAVE v4.01 Alias Manager™"
  size -1 -1 297 197
  option dbu
  icon img/conf.ico, 0
  edit "", 2, 7 11 237 10, autohs
  list 1, 7 23 237 152, size vsbar
  button "Add Alias", 4, 255 10 37 12
  button "Remove", 6, 255 24 37 12
  button "How To?", 7, 255 51 37 12
  button "Close", 8, 255 180 37 12, ok
  text "", 5, 7 178 110 8
  text "Alias Manager™ by acronix", 9, 7 186 78 8
  text "Selected: None", 10, 119 178 124 8
  box "Reading from aliases.ini file", 3, 2 2 248 193
  box "", 11, 252 2 43 39
  box "", 12, 252 45 43 21
  box "", 13, 252 174 43 21
}
alias alias.manager {
  if ($dialog(alias.manager) == $null) { dialog -m alias.manager alias.manager }
  did -b alias.manager 6
  alias.refresh
}
alias alias.refresh {
  did -r alias.manager 1
  set %alias.count 0
  set %alias.view 1
  set %alias.n n $+ %alias.count
  while ($readini(aliases.ini,n,aliases,%alias.n) != $null) {
    did -o alias.manager 1 %alias.view $readini(aliases.ini,n,aliases,%alias.n)
    inc %alias.count 1
    inc %alias.view 1
    set %alias.n n $+ %alias.count
  }
  did -o alias.manager 5 1 Total Number of alias lines: %alias.count aliases
  did -o alias.manager 10 1 Selected: None
}
on *:dialog:alias.manager:sclick:7: {
  if (!$dialog(alias.howto)) { dialog -m alias.howto alias.howto }
}
on *:dialog:alias.manager:sclick:1: {
  if ($did(alias.manager,1).sel != $null) { 
    did -o alias.manager 2 1 $did(alias.manager,1,$did(alias.manager,1).sel).text 
    did -e alias.manager 6
    did -o alias.manager 10 1 Selected: Line $did(alias.manager,1).sel
  }
}
on *:dialog:alias.manager:sclick:4: {
  if ($did(alias.manager,2).text != $null) {
    if ($isalias($gettok($did(alias.manager,2).text,1,32)) == $true) { 
      set %am.replace.alias $input(Sorry $+ $chr(44) $gettok($did(alias.manager,2).text,1,32) Alias already exists. Do you wish $crlf $+ to replace it with your new command?,y,Error)
      if (%am.replace.alias == $true) { goto process }
      halt 
    }
    :process
    if ($gettok($did(alias.manager,2).text,2,32) == $null) { .echo -q $input(You have not entered a command for $gettok($did(alias.manager,2).text,1,32) alias.,68,Error) | halt }
    alias $did(alias.manager,2).text
    set %added.name $gettok($did(alias.manager,2).text,1,32)
    set %added.com $gettok($did(alias.manager,2).text,2-,32)
    saveini | alias.refresh
    echo 10 -at * Successfully added4 %added.name 10as shortcut for executing:4 %added.com
    unset %added.name | unset %added.com | did -b alias.manager 6 | halt
  }
  .echo -q $input(No Entry Detected.,68,Error)
}
on *:dialog:alias.manager:sclick:6: {
  if ($did(alias.manager,1).sel != $null) { 
    alias $gettok($did(alias.manager,1,$did(alias.manager,1).sel).text,1,32)
    set %removed.alias $gettok($did(alias.manager,1,$did(alias.manager,1).sel).text,1,32)
    saveini | alias.refresh
    echo 10 -at * Successfully Removed4 %removed.alias 10From Aliases
    unset %removed.alias | did -b alias.manager 6 | halt


  }
  .echo -q $input(Please select an alias from the list.,68,Error)
}

dialog alias.howto {
  title "How to Use Aliases"
  size -1 -1 241 169
  option dbu
  text "Aliases are simply shortcuts for long commands. For example, if you are tired of always typing your asl whenever someone asks, you can make an alias such as ' /asl ' as a shortcut for executing ' /say 18 F manila '. You can add any command you want. Format is:", 1, 7 6 226 22
  text "/aliasname /command to execute", 2, 71 36 82 8
  text "For example, I want to make a shortcut for noticing users. I would add there:", 3, 25 54 188 9
  text "/n /notice $$1 $$2-", 4, 89 69 48 8
  text "where $$1 is the first word after the /n command and $$2- are the rest of the words starting from the 2nd word after /n. Basically, $$1 is where you enter the nickname you want to notice and $$2- is your notice message. Refer to the help files of mIRC for proper identifiers and strings.", 5, 29 81 180 29
  text "The alias I made above will lessen your notice command. Instead of typing ' /notice siLverbLade hello there ' I could just type ' /n siLverbLade hello there ' instead. Aliases can make you replace your commands for easier use. For further tutorial regarding aliases, refer to the mIRC help menu.", 6, 29 117 180 27
  box "", 7, 2 0 237 154
  button "Close", 8, 100 157 37 10, ok
  text "acronix ® 2015", 9, 3 160 52 8
  text "All Rights Reserved.", 10, 189 160 50 8
}



;•••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••
;================================== Auto-Op List ======================================
;•••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••

dialog rave.auto.op {
  title "RAVE v4.01 Auto Op List"
  size -1 -1 269 131
  option dbu
  icon img/agenda.ico, 0
  button "Add User", 2, 227 13 37 12
  list 1, 5 13 217 113, sort size
  button "Remove", 3, 227 27 37 12
  button "Clear List", 4, 227 64 37 12
  button "Close", 5, 227 115 37 12, cancel
  check "Enable Auto-Op", 6, 6 2 53 10
  button "Advanced", 7, 227 41 37 12, ok
  text "RAVE v4.01 © 2006 All Rights Reserved.", 8, 165 3 101 8
}

on *:dialog:rave.auto.op:sclick:2: { rave.add.auto.op }
on *:dialog:rave.auto.op:sclick:3: { rave.del.auto.op }
on *:dialog:rave.auto.op:sclick:6: {
  if ($did(6).state == 1) { aop ON }
  if ($did(6).state == 0) { aop OFF }
}
on *:dialog:rave.auto.op:sclick:7: {
  .abook
  .echo -at  $+ $color(notice) $+ * Click the Control TAB then Choose OP on the List type to open the Auto-Op List.
}
on *:dialog:rave.auto.op:sclick:4: {
  set %rave.aop.conclear $input(Are you sure you want to Clear the Auto-Op List?,y,Confirm Clear List)
  if (%rave.aop.conclear == $true) { aop -r | rave.aop.refresh }
  unset %rave.aop.conclear
}

alias rave.del.auto.op {
  if ($did(rave.auto.op,1).sel != $null) { 
    set %rave.aop.condel $input(Are you sure you want to delete $gettok($did(rave.auto.op,1,$did(rave.auto.op,1).sel).text,1,32) $crlf $+ from the auto-op list?,y,Confirm Delete)
    if (%rave.aop.condel == $true) {
      aop -r $remove($gettok($did(rave.auto.op,1,$did(rave.auto.op,1).sel).text,1-2,32),$chr(40),$chr(41))
      unset %rave.aop.condel
      rave.aop.refresh
    }
  }
  else { .echo -q $input(Please select an entry on the list.,68,No Entry Selected) }
}

alias rave.aop.list {
  if ($dialog(rave.auto.op) == $null) { dialog -m rave.auto.op rave.auto.op }
  rave.aop.refresh
  if ($aop == $true) { did -c rave.auto.op 6 }
}

alias rave.add.auto.op {
  set %rave.aop.user $$?="Enter User Address (nick!user@host):"
  set %rave.aop.chan $$?="Enter Channels to Auto-Op %rave.aop.user $crlf $+ Ex. #makati #xavier #ravescript"
  aop %rave.aop.user %rave.aop.chan $network
  if ($dialog(rave.auto.op) != $null) { rave.aop.refresh }
  unset %rave.aop.user
  unset %rave.aop.chan
}

alias rave.aop.refresh {
  did -r rave.auto.op 1
  set %aop.loop 1
  while ($aop(%aop.loop) != $null) {
    did -a rave.auto.op 1 $aop(%aop.loop) ( $+ $aop(%aop.loop).type $+ ) - $aop(%aop.loop).network
    inc %aop.loop 1
  }
}

