raw 437:*: { echo 2 -at 2-5[ 4RAVE 5]-3 Cannot change nickname due to admin restriction }
raw 401:*: { echo 2 -at 2-5[ 4RAVE 5]-3 No such nick/channel (4 $2 3) | haltdef }
raw 402:*: { echo 2 -at 2-5[ 4RAVE 5]-3 No such Nick / Server | haltdef }
