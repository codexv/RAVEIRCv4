raw 306:*: { 
  set %mega.away.msg $awaymsg
  check.color mega.away.msg %mega.away.msg
  check.bold mega.away.msg %mega.away.msg
  check.undr mega.away.msg %mega.away.msg
  .echo 10 -at * You have been marked as being Away (Reason: %mega.away.msg $+ )
  set %mega.away.status Away
  set %mega.away.display Back
  haltdef
}
raw 305:*: {
  .echo 10 -at * You are now Back (From: %mega.away.msg $+ )
  set %mega.away.status Back
  set %mega.away.display Away
  unset %mega.away.msg
  haltdef
}
raw 432:*: {
  if (Erroneous Nickname isin $1-) {
    echo 2 -at -5[ 4RAVE 5]-4 $2 3Erroneous Nickname «--
    haltdef
  }
  if (is currently being held by a Services Enforcer isin $2-) {
    echo $color(notice) -st $2-
    if ($istok(%rno.auto.r,$2,32) == $true) {
      set %rno.pls.change $2
      set %rno.request release
      .echo 2 -at -5[ 4RAVE 5]-3 Requesting RELEASE of4 $2 3from NickServ
      .ns release $2 %rno.password. [ $+ [ $2 ] ]
    }
    haltdef
  }
}
on *:notice:*Your ghost has been successfully killed*:?: {
  if (($nick == NickServ) && (%rno.pls.change != $null)) { nick %rno.pls.change }
  unset %rno.pls.change

  unset %rno.request
}
on *:notice:*Password accepted for*:?: {

  if ($nick == NickServ) { if ($istok(%rave.identified.nicks,$strip($remove($4,.)),32) == $false) { set %rave.identified.nicks %rave.identified.nicks $strip($remove($4,.)) } }
}
on *:notice:*nick is owned by someone else*:?: {
  if (($nick == NickServ) && ($istok(%rno.auto.i,$me,32) == $true) && (%rno.dont != 7)) { identify $me %rno.password. [ $+ [ $me ] ] }
}
on *:notice:*The password supplied for*is incorrect*:?: {
  if ($nick == NickServ) && ($strip($5) == %rno.pls.change) {
    rave.nick.organizer %rno.pls.change
    unset %rno.pls.change
  }
}
on *:notice:*The nickname*has been released*:?: {
  if (($nick == NickServ) && (%rno.pls.change == $strip($3))) { nick %rno.pls.change }
  unset %rno.pls.change
  unset %rno.request
}
alias ghost.reattempt {
  .echo 2 -at -5[ 4RAVE 5]-3 Attempting to GHOST4 %rno.pls.change $+ 3...
  .ns ghost %rno.pls.change %rno.password. [ $+ [ %rno.pls.change ] ]
}
alias release.reattempt {
  .echo 2 -at -5[ 4RAVE 5]-3 Requesting RELEASE of4 %rno.pls.change 3 from NickServ
  .ns release %rno.pls.change %rno.password. [ $+ [ %rno.pls.change ] ]
}

