raw 404:*: { echo 2 -at 2-5[ 4RAVE 5]-3 $2- }
raw 405:*: { echo 2 -at 2-5[ 4RAVE 5]-3 You have joined too many channels (Can't Join $2 $+ ) | Haltdef }
raw 406:*: { echo 2 -at 2-5[ 4RAVE 5]-3 There was no such nickname }
raw 422:*: { echo 2 -at 2-5[ 4RAVE 5]-3 MOTD not present in server }
raw 431:*: { echo 2 -at 2-5[ 4RAVE 5]-3 No nickname given }
